{
  "version": 2,
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 0 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.scan2paper.com" }],
      "destination": "https://scan2paper.com/$1",
      "permanent": true
    }
  ]
}